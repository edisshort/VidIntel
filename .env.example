# ─────────────────────────────────────────────────────
# VidIntel AI — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────

# ── Groq API (Required) ───────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Settings ─────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant | llama3-8b-8192
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.1

# ── Embeddings ────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Faster alternative: all-MiniLM-L6-v2

# ── HuggingFace API (optional) ────────────────────────
# Set to use HF Inference API instead of local model (saves ~200MB RAM on server)
# Get free token: https://huggingface.co/settings/tokens
HF_API_KEY=

# ── Retrieval ─────────────────────────────────────────
DEFAULT_TOP_K=5
HYBRID_ALPHA=0.5
# 0.0 = pure BM25 (keyword) | 1.0 = pure vector (semantic)

# ── OCR ───────────────────────────────────────────────
FRAME_INTERVAL_SEC=30
OCR_ENGINE=easyocr
# Options: easyocr | tesseract
OCR_MIN_CONFIDENCE=0.5

# ── ChromaDB ──────────────────────────────────────────
CHROMA_MODE=local
# For remote: set CHROMA_MODE=remote, CHROMA_HOST, CHROMA_PORT
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── CORS (frontend URL) ───────────────────────────────
CORS_ORIGINS=http://localhost:3000
